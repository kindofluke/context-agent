{
  "name": "context-agent-test",
  "artifact": {
    "name": "context-agent",
    "description": "context-agent Gradio + AG-UI server",
    "spec": {
      "containerGroups": [{
        "containers": [{
          "imageUri": "kindofluke/context-agent:latest",
          "port": 8080,
          "primary": true,
          "resourceRequest": {"cpu": 1, "memory": 2147483648},
          "env": [
            {"name": "OPENAI_API_KEY",    "value": "<your-key>"},
            {"name": "OPENAI_MODEL_NAME", "value": "gpt-4o"},
            {"name": "OPENAI_BASE_URL",   "value": "<optional-proxy-url>"}
          ],
          "readinessProbe": {
            "path": "/",
            "port": 8080,
            "initialDelaySeconds": 30,
            "periodSeconds": 10
          }
        }]
      }]
    }
  },
  "runtime": {"replicaCount": 1}
}
